CM_ SG_ 601 Pack2_LostCelTFlt "Any one cell temperature is unavailable or invalid (out of range/rationality) for >500ms";
CM_ SG_ 601 Pack2_I2T_Chg_Flt "I2T Charge Limit Exceeded.";
CM_ SG_ 601 Pack2_LVLoFlt "If low voltage battery voltage lower then 9.5 V for 10s";
CM_ SG_ 601 Pack2_ModHrtbtFlt "Module heartbeat fault or not present.";
CM_ SG_ 601 Pack2_BatCommFlt "If BCM for pack 2 loses communication with any module or CSM for >500ms.";
CM_ SG_ 601 Pack2_CelTmpHiFlt "If any of the Cell temperatures are hotter then 62 degree C for 10s on pack 2.";
CM_ SG_ 601 Pack2_CelOverVFlt "Any of the battery cell voltages are higher than 3.8V for 100ms for pack 2";
CM_ SG_ 601 Pack2_CrashDetected "Crash Detected.";
CM_ SG_ 601 Pack2_LostLVVFlt "If LV battery voltage is unavailable or invalid (out of range/rationality).";
CM_ SG_ 601 Pack2_IsolationFlt "If bettery systems fails isolation test (<500 ohms/V)";
CM_ SG_ 601 Pack2_LostChrCANFlt "No message(s) from OBCM for 1000ms when sending ChargerCMD message.";
